{
  "name": "web-llm-wiki",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:runtime": "node scripts/clean-runtime.mjs && node node_modules/typescript/bin/tsc --outDir .runtime --noEmit false",
    "dev": "npm run build:runtime && node .runtime/src/server.js",
    "start": "npm run build:runtime && node .runtime/src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^17.4.2",
    "hono": "^4.9.6",
    "js-yaml": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
